# Copy to .env (gitignored) and point at YOUR local D2 1.14d install.
# Used by tools/extract_tiles.zig to pull DS1/dt1 tile assets out of the MPQs.
# No machine paths live in the repo — these are yours.

# Dir containing d2data.mpq, d2exp.mpq, Patch_D2.mpq (a 1.14d install).
D2_MPQ_DIR=/path/to/your/d2/install
